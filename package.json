{
  "name": "opensight",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.15.0",
  "pnpm": {
    "overrides": {
      "drizzle-orm": "0.33.0",
      "@neondatabase/serverless": "0.9.5"
    }
  },
  "scripts": {
    "dev": "turbo dev",
    "dev:web": "pnpm --filter @opensight/web dev",
    "dev:inngest": "pnpm --filter @opensight/web dev:inngest",
    "dev:api": "pnpm --filter @opensight/api dev",
    "dev:db": "pnpm --filter @opensight/db dev",
    "dev:analyzer": "pnpm --filter @opensight/analyzer dev",
    "dev:engine-clients": "pnpm --filter @opensight/engine-clients dev",
    "dev:shared": "pnpm --filter @opensight/shared dev",
    "build": "turbo build",
    "build:web": "pnpm --filter @opensight/web build",
    "build:api": "pnpm --filter @opensight/api build",
    "build:db": "pnpm --filter @opensight/db build",
    "build:analyzer": "pnpm --filter @opensight/analyzer build",
    "build:engine-clients": "pnpm --filter @opensight/engine-clients build",
    "build:shared": "pnpm --filter @opensight/shared build",
    "start:web": "pnpm --filter @opensight/web start",
    "start:api": "pnpm --filter @opensight/api start",
    "lint": "turbo lint",
    "lint:fix": "turbo lint -- --fix",
    "db:generate": "pnpm --filter @opensight/db generate",
    "db:migrate": "pnpm --filter @opensight/db migrate",
    "db:seed": "pnpm --filter @opensight/db seed",
    "db:setup": "pnpm db:generate && pnpm db:migrate && pnpm db:seed",
    "docker:up": "docker compose -f docker/docker-compose.dev.yml up -d",
    "docker:down": "docker compose -f docker/docker-compose.dev.yml down",
    "docker:prod": "docker compose -f docker/docker-compose.yml up -d",
    "docker:prod:down": "docker compose -f docker/docker-compose.yml down",
    "setup": "pnpm install && pnpm docker:up && pnpm db:setup",
    "start": "pnpm docker:up && turbo dev"
  },
  "devDependencies": {
    "@types/node-cron": "^3.0.11",
    "turbo": "^2.0.0",
    "typescript": "^5.5.0"
  }
}
